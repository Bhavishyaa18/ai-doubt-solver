# Copy this file to .env.local and fill in your API key
# Run: cp .env.example .env.local

# RECOMMENDED: Groq API (FREE - no credit card needed)
# Get your free key at: console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Which provider to use: "groq", "openai", or "anthropic"
AI_PROVIDER=groq

# -----------------------------------------------
# Optional: Switch to OpenAI later (paid)
# Get key at: platform.openai.com
# OPENAI_API_KEY=your_openai_api_key_here
# AI_PROVIDER=openai

# Optional: Anthropic/Claude (has free trial credits)
# Get key at: console.anthropic.com
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# AI_PROVIDER=anthropic
